DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
BETTER_AUTH_SECRET=generate-a-random-32-char-string-here
BETTER_AUTH_URL=http://localhost:3000

# AI (chat concierge + scraper enrichment). The bearer token is a Bedrock session token;
# both the scraper and the API worker read it. The model var is shared too.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-sonnet-4-6
