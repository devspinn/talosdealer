    "better-auth": "^1.2.0",
    "drizzle-orm": ">=0.41.0",
    "hono": "^4.7.0",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
